package rasmcore:image@0.1.0;

/// Image quality comparison metrics.
interface compare {
    use rasmcore:core/types.{buffer, image-info};
    use rasmcore:core/errors.{rasmcore-error};

    /// Peak Signal-to-Noise Ratio in dB (8-bit images).
    /// Returns infinity for identical images.
    psnr: func(a: buffer, info-a: image-info, b: buffer, info-b: image-info) -> result<f64, rasmcore-error>;

    /// Structural Similarity Index (Wang et al. 2004).
    /// Returns 1.0 for identical images. Requires images >= 11x11.
    ssim: func(a: buffer, info-a: image-info, b: buffer, info-b: image-info) -> result<f64, rasmcore-error>;

    /// Root Mean Squared Error.
    rmse: func(a: buffer, info-a: image-info, b: buffer, info-b: image-info) -> result<f64, rasmcore-error>;

    /// Mean Absolute Error.
    mae: func(a: buffer, info-a: image-info, b: buffer, info-b: image-info) -> result<f64, rasmcore-error>;

    /// Mean CIE76 Delta E via sRGB to Lab conversion.
    /// Requires RGB8 or RGBA8 images.
    delta-e-cie76: func(a: buffer, info-a: image-info, b: buffer, info-b: image-info) -> result<f64, rasmcore-error>;
}
