package rasmcore:image@0.1.0;

/// Demand-driven image processing pipeline.
///
/// Build a graph of operations, then execute via write(). The pipeline
/// owns all nodes internally — node-id values are opaque handles.
/// Pixels are computed on demand, cached, and reused automatically.
interface pipeline {
    use rasmcore:core/types.{buffer, image-info, pixel-format};
    use rasmcore:core/errors.{rasmcore-error};
    use metadata.{exif-orientation, metadata-set};

    /// Opaque handle to a node in the pipeline's internal graph.
    type node-id = u32;

    /// Resize filter algorithms.
    enum resize-filter { nearest, bilinear, bicubic, lanczos3 }

    /// Rotation amounts.
    enum rotation { r90, r180, r270 }

    /// Flip direction.
    enum flip-direction { horizontal, vertical }

    /// JPEG write configuration.
    record jpeg-write-config {
        quality: option<u8>,
        /// Emit progressive JPEG (default: false)
        progressive: option<bool>,
    }

    /// PNG filter type (mirrors encoder png-filter-type).
    enum png-filter-type {
        no-filter,
        sub,
        up,
        avg,
        paeth,
        adaptive,
    }

    /// PNG write configuration.
    record png-write-config {
        compression-level: option<u8>,
        filter-type: option<png-filter-type>,
    }

    /// WebP write configuration.
    record webp-write-config {
        quality: option<u8>,
        lossless: option<bool>,
    }

    /// TIFF compression algorithm (mirrors encoder tiff-compression).
    enum tiff-compression {
        none,
        lzw,
        deflate,
        packbits,
    }

    /// TIFF write configuration.
    record tiff-write-config {
        compression: option<tiff-compression>,
    }

    /// AVIF write configuration.
    record avif-write-config {
        quality: option<u8>,
        speed: option<u8>,
    }

    /// BMP write configuration. No meaningful parameters.
    record bmp-write-config {
        reserved: option<bool>,
    }

    /// ICO write configuration. No meaningful parameters.
    record ico-write-config {
        reserved: option<bool>,
    }

    /// QOI write configuration. No meaningful parameters.
    record qoi-write-config {
        reserved: option<bool>,
    }

    /// GIF write configuration.
    record gif-write-config {
        repeat: option<u16>,
    }

    /// The pipeline resource — owns the node graph and spatial cache.
    resource image-pipeline {
        /// Create a new empty pipeline.
        constructor();

        // ─── Source ───

        /// Read encoded image data into the pipeline. Returns a source node.
        /// Does NOT decode pixels until a downstream write() requests them.
        read: func(data: buffer) -> result<node-id, rasmcore-error>;

        /// Get image info for a node (dimensions, format — no pixel computation).
        node-info: func(node: node-id) -> result<image-info, rasmcore-error>;

        // ─── Transforms ───

        /// Resize to exact dimensions.
        resize: func(source: node-id, width: u32, height: u32, filter: resize-filter) -> result<node-id, rasmcore-error>;

        /// Crop a rectangular region.
        crop: func(source: node-id, x: u32, y: u32, width: u32, height: u32) -> result<node-id, rasmcore-error>;

        /// Rotate by fixed angle.
        rotate: func(source: node-id, angle: rotation) -> result<node-id, rasmcore-error>;

        /// Flip horizontally or vertically.
        flip: func(source: node-id, direction: flip-direction) -> result<node-id, rasmcore-error>;

        /// Convert pixel format.
        convert-format: func(source: node-id, target: pixel-format) -> result<node-id, rasmcore-error>;

        /// Convert from embedded ICC color profile to sRGB.
        /// The ICC profile is an opaque binary blob extracted during decode.
        /// No-op if the source node has no ICC profile or is already sRGB.
        icc-to-srgb: func(source: node-id, icc-profile: buffer) -> result<node-id, rasmcore-error>;

        /// Auto-orient using EXIF orientation value.
        auto-orient: func(source: node-id, orientation: exif-orientation) -> result<node-id, rasmcore-error>;

        // ─── Filters ───
        //
        // Each filter has a precisely typed method.
        // Generated by build script from #[register_filter] annotations.

        /// Gaussian blur.
        blur: func(source: node-id, radius: f32) -> result<node-id, rasmcore-error>;

        /// Sharpen (unsharp mask).
        sharpen: func(source: node-id, amount: f32) -> result<node-id, rasmcore-error>;

        /// Brightness adjustment (-1.0 to 1.0).
        brightness: func(source: node-id, amount: f32) -> result<node-id, rasmcore-error>;

        /// Contrast adjustment (-1.0 to 1.0).
        contrast: func(source: node-id, amount: f32) -> result<node-id, rasmcore-error>;

        /// Convert to grayscale.
        grayscale: func(source: node-id) -> result<node-id, rasmcore-error>;

        /// Apply NxN convolution with custom kernel.
        convolve: func(source: node-id, kernel: list<f32>, kernel-width: u32, kernel-height: u32, divisor: f32) -> result<node-id, rasmcore-error>;

        /// Median filter with given radius.
        median: func(source: node-id, radius: u32) -> result<node-id, rasmcore-error>;

        /// Sobel edge detection (grayscale gradient magnitude output).
        sobel: func(source: node-id) -> result<node-id, rasmcore-error>;

        /// Canny edge detection (binary edge map output).
        canny: func(source: node-id, low-threshold: f32, high-threshold: f32) -> result<node-id, rasmcore-error>;

        // ─── Compositing ───

        /// Alpha composite foreground over background (Porter-Duff "over").
        /// Places fg at (x, y) offset on bg. Both must be RGBA8.
        /// Output dimensions match the background.
        composite: func(fg: node-id, bg: node-id, x: s32, y: s32) -> result<node-id, rasmcore-error>;

        // ─── Metadata ───

        /// Read metadata from the source data without decoding pixels.
        /// Returns a JSON string with all metadata containers.
        metadata-dump: func() -> result<string, rasmcore-error>;

        /// Read a single metadata value by dot-path (e.g., "exif.Artist").
        /// Returns None for valid paths where the field is absent.
        metadata-read: func(path: string) -> result<option<string>, rasmcore-error>;

        /// Opt-in to carry source metadata through to the output.
        /// Without this, output has NO metadata from source (safe default).
        keep-metadata: func() -> result<node-id, rasmcore-error>;

        /// Set a metadata field by dot-path. Chainable — applied at encode time.
        /// Works with or without keep-metadata.
        set-metadata: func(path: string, value: string) -> result<node-id, rasmcore-error>;

        /// Bulk-set metadata from a JSON object (inverse of metadata-dump).
        /// Validates all containers and fields. Applied at encode time.
        load-metadata: func(json: string) -> result<node-id, rasmcore-error>;

        /// Remove a metadata field or container. Only meaningful after keep-metadata.
        /// Without keep-metadata, this is a no-op.
        strip-metadata: func(path: string) -> result<node-id, rasmcore-error>;

        // ─── Write (drives execution) ───

        /// Write as JPEG. Pulls all regions through the graph.
        /// If metadata is provided, it is embedded into the output.
        write-jpeg: func(source: node-id, config: jpeg-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;

        /// Write as PNG. If metadata is provided, it is embedded.
        write-png: func(source: node-id, config: png-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;

        /// Write as WebP. If metadata is provided, it is embedded.
        write-webp: func(source: node-id, config: webp-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;

        /// Write as AVIF.
        write-avif: func(source: node-id, config: avif-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;

        /// Write as TIFF.
        write-tiff: func(source: node-id, config: tiff-write-config) -> result<buffer, rasmcore-error>;

        /// Write as BMP.
        write-bmp: func(source: node-id, config: bmp-write-config) -> result<buffer, rasmcore-error>;

        /// Write as ICO.
        write-ico: func(source: node-id, config: ico-write-config) -> result<buffer, rasmcore-error>;

        /// Write as QOI.
        write-qoi: func(source: node-id, config: qoi-write-config) -> result<buffer, rasmcore-error>;

        /// Write as GIF. If metadata is provided, it is embedded.
        write-gif: func(source: node-id, config: gif-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;

        /// Write to any format (convenience). If metadata is provided, it is embedded.
        write: func(source: node-id, format: string, quality: option<u8>, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;
    }

    /// Detect image format from header bytes.
    detect-format: func(header: buffer) -> option<string>;

    /// List supported read formats.
    supported-read-formats: func() -> list<string>;

    /// List supported write formats.
    supported-write-formats: func() -> list<string>;
}
