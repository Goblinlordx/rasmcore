package rasmcore:image@0.1.0;

/// Image encoding to various formats
interface encoder {
    use rasmcore:core/types.{buffer, image-info};
    use rasmcore:core/errors.{rasmcore-error};

    /// JPEG encode configuration
    record jpeg-encode-config {
        /// Quality level 1-100 (default: 85)
        quality: option<u8>,
        /// Emit progressive JPEG (default: false)
        progressive: option<bool>,
    }

    /// PNG filter type for pre-compression filtering (ISO/IEC 15948 Section 9).
    enum png-filter-type {
        /// No filtering.
        no-filter,
        /// Byte difference from left neighbor.
        sub,
        /// Byte difference from above neighbor.
        up,
        /// Average of left and above neighbors.
        avg,
        /// Paeth predictor.
        paeth,
        /// Encoder selects optimal filter per row (best compression, default).
        adaptive,
    }

    /// PNG encode configuration
    record png-encode-config {
        /// Compression level 0-9 where 0=none, 9=max (default: 6)
        compression-level: option<u8>,
        /// Filter type selection (default: adaptive)
        filter-type: option<png-filter-type>,
    }

    /// WebP encode configuration
    record webp-encode-config {
        /// Quality level 1-100 for lossy mode (default: 75)
        quality: option<u8>,
        /// Use lossless encoding (default: false)
        lossless: option<bool>,
    }

    /// TIFF compression algorithm.
    enum tiff-compression {
        /// No compression.
        none,
        /// LZW compression (default, good general-purpose lossless).
        lzw,
        /// Deflate/zlib compression (better ratio, slower).
        deflate,
        /// PackBits run-length encoding (fast, moderate compression).
        packbits,
    }

    /// TIFF encode configuration
    record tiff-encode-config {
        /// Compression algorithm (default: lzw)
        compression: option<tiff-compression>,
    }

    /// GIF encode configuration
    record gif-encode-config {
        /// Repeat count: 0 = infinite loop, n = repeat n times (default: 0)
        repeat: option<u16>,
    }

    /// Encode pixel data to JPEG with typed configuration
    encode-jpeg: func(pixels: buffer, info: image-info, config: jpeg-encode-config) -> result<buffer, rasmcore-error>;

    /// Encode pixel data to JPEG with an embedded ICC profile
    encode-jpeg-with-icc: func(pixels: buffer, info: image-info, config: jpeg-encode-config, icc-profile: buffer) -> result<buffer, rasmcore-error>;

    /// Encode pixel data to PNG with typed configuration
    encode-png: func(pixels: buffer, info: image-info, config: png-encode-config) -> result<buffer, rasmcore-error>;

    /// Encode pixel data to PNG with an embedded ICC profile
    encode-png-with-icc: func(pixels: buffer, info: image-info, config: png-encode-config, icc-profile: buffer) -> result<buffer, rasmcore-error>;

    /// Encode pixel data to WebP with typed configuration
    encode-webp: func(pixels: buffer, info: image-info, config: webp-encode-config) -> result<buffer, rasmcore-error>;

    /// Encode pixel data to TIFF with typed configuration
    encode-tiff: func(pixels: buffer, info: image-info, config: tiff-encode-config) -> result<buffer, rasmcore-error>;

    /// Encode pixel data to GIF with typed configuration
    encode-gif: func(pixels: buffer, info: image-info, config: gif-encode-config) -> result<buffer, rasmcore-error>;

    /// Encode pixel data to a specific format (convenience wrapper)
    encode: func(pixels: buffer, info: image-info, format: string, quality: option<u8>) -> result<buffer, rasmcore-error>;

    /// List supported encode formats
    supported-formats: func() -> list<string>;
}
