package rasmcore:image@0.1.0;

/// Image encoding — dynamic dispatch via format string.
///
/// All encoding goes through the generic `encode()` function which
/// dispatches to registered encoders by format name. Per-format config
/// is passed as a JSON string; SDKs generate typed wrappers from the
/// param manifest.
interface encoder {
    use rasmcore:core/types.{buffer, image-info, format-info};
    use rasmcore:core/errors.{rasmcore-error};
    use decoder.{frame-info};

    /// Encode pixel data to the specified format.
    ///
    /// The format string selects the encoder (e.g., "jpeg", "png", "webp").
    /// Quality is an optional 1-100 hint used by lossy formats.
    /// For fine-grained control, pass a config JSON string.
    encode: func(pixels: buffer, info: image-info, format: string, quality: option<u8>) -> result<buffer, rasmcore-error>;

    /// Encode with an embedded ICC color profile.
    ///
    /// The ICC profile is embedded in the output container if the format
    /// supports it (JPEG, PNG). For unsupported formats, the profile is ignored.
    encode-with-icc: func(pixels: buffer, info: image-info, format: string, quality: option<u8>, icc-profile: buffer) -> result<buffer, rasmcore-error>;

    /// List supported encode formats (e.g., ["jpeg", "png", "webp", ...]).
    supported-formats: func() -> list<string>;

    /// Get format metadata (MIME type, extensions) for a specific format.
    get-format-info: func(format: string) -> option<format-info>;

    /// Get format metadata for all supported encode formats.
    all-format-info: func() -> list<format-info>;

    // ─── Multi-Frame / Multi-Page Encoding ───

    /// A frame in a sequence: image pixels + per-frame metadata.
    record encode-frame {
        pixels: buffer,
        info: image-info,
        frame-info: frame-info,
    }

    /// Encode a frame sequence to a multi-frame format.
    ///
    /// Format string selects the encoder (e.g., "gif", "tiff", "apng").
    /// Quality is an optional 1-100 hint.
    encode-sequence: func(frames: list<encode-frame>, canvas-width: u32, canvas-height: u32, format: string, quality: option<u8>) -> result<buffer, rasmcore-error>;
}
