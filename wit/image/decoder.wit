package rasmcore:image@0.1.0;

/// Image format detection and decoding
interface decoder {
    use rasmcore:core/types.{buffer, image-info, pixel-format};
    use rasmcore:core/errors.{rasmcore-error};

    /// Decoded image data with metadata
    record decoded-image {
        pixels: buffer,
        info: image-info,
        /// Embedded ICC color profile (opaque binary), if present in source image
        icc-profile: option<buffer>,
    }

    /// Detect image format from header bytes
    detect-format: func(header: buffer) -> option<string>;

    /// Decode an image from a buffer
    decode: func(data: buffer) -> result<decoded-image, rasmcore-error>;

    /// Decode with specific output pixel format
    decode-as: func(data: buffer, target-format: pixel-format) -> result<decoded-image, rasmcore-error>;

    /// List supported decode formats
    supported-formats: func() -> list<string>;

    // ─── Multi-Frame / Multi-Page ───

    /// Frame disposal method for animated images.
    enum disposal-method {
        /// No disposal — leave frame in place.
        none,
        /// Restore to background color.
        background,
        /// Restore to previous frame.
        previous,
    }

    /// Per-frame metadata.
    record frame-info {
        index: u32,
        delay-ms: u32,
        disposal: disposal-method,
        width: u32,
        height: u32,
        x-offset: u32,
        y-offset: u32,
    }

    /// A decoded frame: image data plus frame metadata.
    record decoded-frame {
        image: decoded-image,
        info: frame-info,
    }

    /// Count frames/pages without full decode (1 for single-frame formats).
    frame-count: func(data: buffer) -> result<u32, rasmcore-error>;

    /// Decode a specific frame by zero-based index.
    decode-frame: func(data: buffer, index: u32) -> result<decoded-frame, rasmcore-error>;

    /// Decode all frames/pages.
    decode-all-frames: func(data: buffer) -> result<list<decoded-frame>, rasmcore-error>;
}
