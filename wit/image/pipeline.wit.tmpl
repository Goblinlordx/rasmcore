package rasmcore:image@0.1.0;

/// Demand-driven image processing pipeline — AUTO-GENERATED by build.rs
///
/// Do not edit pipeline.wit directly. Edit pipeline.wit.tmpl instead.
/// Filter/transform methods are auto-generated from annotations.
interface pipeline {
    use rasmcore:core/types.{buffer, image-info, pixel-format, point2d};
    use rasmcore:core/errors.{rasmcore-error};
    use metadata.{exif-orientation, metadata-set};
{{GENERATED_FILTER_IMPORTS}}

    /// Opaque handle to a node in the pipeline's internal graph.
    type node-id = u32;

    /// JPEG write configuration.
    record jpeg-write-config {
        quality: option<u8>,
        progressive: option<bool>,
        turbo: option<bool>,
    }

    enum png-filter-type {
        no-filter, sub, up, avg, paeth, adaptive,
    }

    record png-write-config {
        compression-level: option<u8>,
        filter-type: option<png-filter-type>,
    }

    record webp-write-config {
        quality: option<u8>,
        lossless: option<bool>,
    }

    enum tiff-compression { none, lzw, deflate, packbits }

    record tiff-write-config {
        compression: option<tiff-compression>,
    }

    record avif-write-config {
        quality: option<u8>,
        speed: option<u8>,
    }

    record bmp-write-config { reserved: option<bool> }
    record ico-write-config { reserved: option<bool> }
    record qoi-write-config { reserved: option<bool> }
    record gif-write-config { repeat: option<u16> }

    // ─── Transform types (auto-generated from #[register_transform]) ───
{{GENERATED_TRANSFORM_TYPES}}

    variant frame-selection {
        single(u32),
        pick(list<u32>),
        %range(tuple<u32, u32>),
        all,
    }

    /// Layer cache for reusing intermediate results across pipeline executions.
    record cache-stats {
        entries: u64,
        hits: u64,
        misses: u64,
        size-bytes: u64,
    }

    /// Cache storage quality for layer cache entries.
    enum cache-quality {
        /// Full precision — store cached tiles as-is (default).
        full,
        /// Quantize to 16-bit per channel (halves memory).
        q16,
        /// Quantize to 8-bit per channel (quarters memory).
        q8,
    }

    resource layer-cache {
        constructor(capacity: u32);
        stats: func() -> cache-stats;
        clear: func();
        /// Set the storage quality for new cache entries.
        set-cache-quality: func(quality: cache-quality);
    }

    /// Pipeline precision mode.
    enum pipeline-precision {
        /// Standard 8-bit processing (default).
        standard,
        /// Half-precision 16-bit float processing. 2x memory per pixel.
        half-precision,
        /// High-precision 32-bit float processing. 4x memory per pixel.
        high-precision,
    }

    resource image-pipeline {
        constructor();

        // ─── Configuration ───
        set-precision: func(precision: pipeline-precision);
        /// Set proxy scale factor for automatic spatial parameter scaling.
        /// Spatial params (hint = rc.pixels) are multiplied by this factor.
        /// Default 1.0 = full resolution. Use 0.5 for half-resolution proxy.
        set-proxy-scale: func(scale: f32);

        // ─── Source ───
        read: func(data: buffer) -> result<node-id, rasmcore-error>;
        read-frames: func(data: buffer, selection: frame-selection) -> result<node-id, rasmcore-error>;
        node-info: func(node: node-id) -> result<image-info, rasmcore-error>;
        set-layer-cache: func(cache: borrow<layer-cache>);

        // ─── Transforms (auto-generated from #[register_transform]) ───
{{GENERATED_PIPELINE_TRANSFORMS}}
        convert-format: func(source: node-id, target: pixel-format) -> result<node-id, rasmcore-error>;

        // ─── Filters (auto-generated from #[register_filter]) ───

{{GENERATED_PIPELINE_FILTERS}}

        // ─── Metadata ───
        metadata-dump: func() -> result<string, rasmcore-error>;
        metadata-read: func(path: string) -> result<option<string>, rasmcore-error>;
        node-metadata-dump: func(source: node-id) -> result<string, rasmcore-error>;
        node-metadata-read: func(source: node-id, path: string) -> result<option<string>, rasmcore-error>;
        keep-metadata: func() -> result<node-id, rasmcore-error>;
        set-metadata: func(path: string, value: string) -> result<node-id, rasmcore-error>;
        load-metadata: func(json: string) -> result<node-id, rasmcore-error>;
        strip-metadata: func(path: string) -> result<node-id, rasmcore-error>;
        include-metadata: func(patterns: list<string>);
        exclude-metadata: func(patterns: list<string>);

        // ─── Write ───
        write-jpeg: func(source: node-id, config: jpeg-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;
        write-png: func(source: node-id, config: png-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;
        write-webp: func(source: node-id, config: webp-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;
        write-avif: func(source: node-id, config: avif-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;
        write-tiff: func(source: node-id, config: tiff-write-config) -> result<buffer, rasmcore-error>;
        write-bmp: func(source: node-id, config: bmp-write-config) -> result<buffer, rasmcore-error>;
        write-ico: func(source: node-id, config: ico-write-config) -> result<buffer, rasmcore-error>;
        write-qoi: func(source: node-id, config: qoi-write-config) -> result<buffer, rasmcore-error>;
        write-gif: func(source: node-id, config: gif-write-config, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;
        write: func(source: node-id, format: string, quality: option<u8>, metadata: option<metadata-set>) -> result<buffer, rasmcore-error>;

        // ─── Multi-Frame ───
        execute-sequence: func(source: node-id, output: node-id) -> result<u32, rasmcore-error>;

        // ─── Script Plugins ───
        /// Load script plugin sources. Each string is a complete Rhai script
        /// with metadata header (//! name, //! strategy, etc.).
        /// Scripts are compiled and validated; errors are returned immediately.
        /// Call this before apply-script-filter.
        load-scripts: func(sources: list<string>) -> result<_, rasmcore-error>;

        /// Apply a previously loaded script filter by name.
        /// Config is a list of (key, value) string pairs parsed by the script.
        apply-script-filter: func(name: string, source: node-id, config: list<tuple<string, string>>) -> result<node-id, rasmcore-error>;

        /// List the names of all loaded script filters.
        list-script-filters: func() -> list<string>;

        // ─── Graph Description ───
        /// Return the graph description as a JSON string.
        /// Lists all nodes with their kind, name, upstreams, and output info.
        graph-describe: func() -> string;
        /// Return the graph description as compact binary bytes.
        graph-serialize: func() -> buffer;
        /// Return the number of nodes in the graph.
        graph-node-count: func() -> u32;
        /// Execute a pipeline from a serialized graph description + source data.
        /// The description is not consumed — it can be re-executed.
        write-from-description: func(description: buffer, source-data: buffer, terminal-node: node-id, format: string, quality: option<u8>) -> result<buffer, rasmcore-error>;
    }

    /// A single operation in a processing chain.
    /// Operations with no params use an empty list.
    record chain-op {
        name: string,
        params: list<f32>,
    }

    /// Execute a full image processing chain in one call.
    ///
    /// Input and output images are base64-encoded to enable easy transport
    /// across any host language (Go, Perl, PHP, Ruby, etc.) via the wasmtime
    /// CLI's WAVE text format — no binary serialization required.
    ///
    /// Example WAVE invocation:
    ///   process-chain("iVBOR...", [{name: "invert", params: []}, {name: "blur", params: [5.0]}], "png", none)
    process-chain: func(input-b64: string, ops: list<chain-op>, output-format: string, quality: option<u8>) -> result<string, rasmcore-error>;

    detect-format: func(header: buffer) -> option<string>;
    supported-read-formats: func() -> list<string>;
    supported-write-formats: func() -> list<string>;

    /// Return the full filter/operation manifest as JSON.
    /// Contains all registered filters, generators, compositors, and mappers
    /// with parameter names, types, ranges, defaults, and UI hints.
    /// Enables runtime introspection — no external manifest file needed.
    get-filter-manifest: func() -> string;

    /// Return a hash of the manifest for version validation.
    /// Generated typed SDKs embed this hash and warn when the loaded
    /// module differs from the version the SDK was generated against.
    get-manifest-hash: func() -> string;
}
